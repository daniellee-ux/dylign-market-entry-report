# Whitelist: ignore everything at root, then re-include only the deployable site.
/*
!/.gitignore
!/.nojekyll
!/README.md
!/index.html
!/board/
!/prototype/

# never track macOS cruft, even inside whitelisted dirs
.DS_Store
**/.DS_Store

# board screenshots: only the referenced subset is tracked (52 files used by the step viewer)
board/screenshots/
